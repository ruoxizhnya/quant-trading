# ── Credentials (never commit) ──────────────────
.github-token
.env
.env.local
.env.*.local

# ── IDE ────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.sublime-workspace
.sublime-project

# ── OS ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.log

# ── Go ─────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
/test/
*_test.go
*.test
*.out
/bin/
/dist/

# Source test files (Go convention: *_test.go) are ignored by the rule above.
# Pre-existing tracked test files (e.g. pkg/storage/postgres_test.go) remain
# tracked because they were committed before the rule was added. New tests
# can be added explicitly with `git add -f path/to/file_test.go`.

# Go coverage / profiling
*.prof
*.pprof
coverage.html
coverage.out

# ── Node.js / Frontend (web/) ──────────────────
# Root-level node_modules (e.g. from running npx at repo root) — never commit.
node_modules/
web/node_modules/
web/dist/
web/.vite/
web/.cache/
web/tsconfig.tsbuildinfo
web/.eslintcache
web/.parcel-cache

# ── E2E Test Artifacts ─────────────────────────
e2e/node_modules/
e2e/test-results/
e2e/e2e-report/
e2e/playwright-report/

# ── Python / AI ────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ── Docker ─────────────────────────────────────
docker-compose.override.yml

# ── Generated / Temp Files ─────────────────────
FRONTEND_*.md
*.bak
*.tmp
*.temp

# ── AI Session State (gitignored, per-session) ─────
.session/
.session/*
